{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://stira.dev/spec/state.schema.json",
  "title": "Stira State",
  "description": "Agent behavioral state vector with metadata",
  "type": "object",
  "required": ["version", "params", "updated"],
  "properties": {
    "version": {
      "type": "integer",
      "description": "Schema version for migration support",
      "const": 1
    },
    "params": {
      "type": "object",
      "description": "Parameter name → current value [0.0, 1.0]",
      "required": ["stability", "vigilance"],
      "properties": {
        "stability": { "type": "number", "minimum": 0, "maximum": 1 },
        "vigilance": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
    },
    "updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of last state change"
    },
    "transcription": {
      "type": "string",
      "description": "Natural language description of current state (optional, LLM-generated)"
    },
    "activeBreakers": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of currently active circuit breakers"
    }
  }
}
